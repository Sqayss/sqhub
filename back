                                st.lastLog = os.time()
                            end
                            -- 7 saniye kala combat'ı durdur
                            if sec <= 7 then
                                S.trialActive = true
                            end
                            if sec <= 5 and not st.teleported then
                                print("[AUTO JOIN "..diff.."] Countdown ≤5s, teleporting...")
                                local teleportOk = teleportTo(Trials[diff].coord)
                                if teleportOk then
                                    print("[AUTO JOIN "..diff.."] Teleport successful!")
                                    st.teleported = true
                                else
                                    warn("[AUTO JOIN "..diff.."] Teleport failed!")
                                    S.trialActive = false
                                end
                            end
                            if sec > 5 then 
                                st.teleported = false
                                -- Teleport sonrası combat'ı serbest bırak (trial odasında grind ederken çalışması için)
                                if st.teleported then
                                    S.trialActive = false
                                end
                            end
                        end
                    else
                        if os.time() - st.lastLog >= 30 then
                            warn("[AUTO JOIN "..diff.."] Countdown label not found!")
                            st.lastLog = os.time()
                        end
                    end
                else
                    st.listening = false
                end
            end
        end)
        if not success then
            warn("[AUTO JOIN ERROR] " .. tostring(err))
            task.wait(10)
        else
            task.wait(5)
        end
    end
end)

-- Grind + Wave + Leave + 2s Return (trial odasında combat çalışır)
for diff, data in pairs(Trials) do
    local st = TrialState[diff]
    task.spawn(function()
        while not env.NIStop do
            local ok, err = pcall(function()
                if st.walk then
                    local char = LP.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then task.wait(0.3); return end
                    local room = WS:FindFirstChild("__GAME_CONTENT") and WS.__GAME_CONTENT:FindFirstChild("Trials") and WS.__GAME_CONTENT.Trials:FindFirstChild(data.room)
                    if not room then task.wait(0.3); return end
                    -- Trial odasındayız ama combat'ı durdurma (grind ederken çalışması için)
                    local target = findTrialMob(diff)
                    local alive = 0
                    for _, v in ipairs(room:GetDescendants()) do
                        if v:IsA("Humanoid") and v.Health > 0 and v.Parent ~= char then alive = alive + 1 end
                    end
                    if target and (hrp.Position - target.Position).Magnitude > 5 then
                        local tw = TS:Create(hrp, TweenInfo.new(0.3, Enum.EasingStyle.Linear), {CFrame = CFrame.new(target.Position)})
                        tw:Play(); tw.Completed:Wait()
                    end
                    if st.prevCount > 0 and alive == 0 then
                        st.wave = st.wave + 1
                        print("["..diff.." WAVE] Wave "..st.wave)
                        if st.autoLeave and st.leaveWave > 0 and st.wave >= st.leaveWave then
                            print("[AUTO LEAVE] Leaving "..diff.." trial at wave "..st.wave)
                            pcall(function() game:GetService("ReplicatedStorage").__Net.MainRemote:FireServer("LeaveTrial") end)
                            st.walk = false
                            st.wave = 1
                            st.prevCount = -1
                            pcall(function() Rayfield.Flags["trialWalk_"..diff] = false end)
                            if st.autoReturn and st.capturedPos then
                                task.delay(2, function()
                                    print("[RETURN] Returning to captured position...")
                                    teleportTo(st.capturedPos)
                                end)
                            end
                        end
                    end
                    st.prevCount = alive
                end
            end)
            if not ok then warn("[GRIND "..diff.." ERROR] " .. tostring(err)) end
            task.wait(0.3)
        end
    end)
end

