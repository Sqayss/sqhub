local function teleportTo(pos)
    local ok, result = pcall(function()
        local char = LP.Character
        if not char then return false end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        hrp.CFrame = CFrame.new(pos)
        pcall(function() hrp.AssemblyLinearVelocity = Vector3.new() end)
        return true
    end)
    if not ok then warn("[TELEPORT] Exception: " .. tostring(result)); return false end
    return result
end
local function getCountdownLabel(diff)
    local obj = WS
    for _, name in ipairs(Trials[diff].path) do if obj then obj = obj:FindFirstChild(name) end end
    if obj and obj:IsA("TextLabel") then return obj end
    for _, v in ipairs(WS:GetDescendants()) do
        if v:IsA("TextLabel") and v.Name:lower():find("timer") and v.Text:lower():find("trial") then return v end
    end
    return nil
end
local function parseCountdown(text)
    if not text then return 0 end
    local min = tonumber(text:match("(%d+)m")) or 0
    local sec = tonumber(text:match("(%d+)s")) or 0
    return min * 60 + sec
end
local function findTrialMob(diff)
    local room = WS:FindFirstChild("__GAME_CONTENT") and WS.__GAME_CONTENT:FindFirstChild("Trials") and WS.__GAME_CONTENT.Trials:FindFirstChild(Trials[diff].room)
    if not room then return nil end
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, v in ipairs(room:GetDescendants()) do
        if v:IsA("Humanoid") and v.Health > 0 and v.Parent ~= LP.Character then
            local root = v.Parent:FindFirstChild("HumanoidRootPart") or v.Parent.PrimaryPart
            if root and root:IsA("BasePart") then
                local d = (hrp.Position - root.Position).Magnitude
                if d < bestDist then bestDist = d; best = root end
            end
        end
    end
    return best
end

